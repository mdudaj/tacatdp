# TACATDP local deployment configuration template.
# Copy to .env locally. Do not commit real tenant IDs, client secrets, tokens, or environment URLs.

# Auth profile
PAC_AUTH_NAME=tacatdp-dev
POWER_PLATFORM_CLOUD=Public
POWER_PLATFORM_AUTH_MODE=servicePrincipal

# Tenant/app auth
POWER_PLATFORM_TENANT_ID=
POWER_PLATFORM_CLIENT_ID=
POWER_PLATFORM_CLIENT_SECRET=

# Target dev environment
POWER_PLATFORM_ENVIRONMENT_ID=
POWER_PLATFORM_ENVIRONMENT_URL=

# Solution identity
POWER_PLATFORM_SOLUTION_UNIQUE_NAME=tacatdp_prototype
POWER_PLATFORM_SOLUTION_DISPLAY_NAME=TACATDP Prototype
POWER_PLATFORM_PUBLISHER_NAME=TACATDP
POWER_PLATFORM_PUBLISHER_PREFIX=mp

# Deployment mode/safety
TACATDP_DEPLOY_TARGET=dev
TACATDP_SCHEMA_SCOPE=prototype-slice-1
TACATDP_DRY_RUN=true
TACATDP_ALLOW_ENVIRONMENT_WRITE=false

# Paths
TACATDP_DATAVERSE_SCHEMA_DIR=schemas/dataverse
TACATDP_SOLUTION_DIR=solution
TACATDP_DEPLOYMENT_SETTINGS_FILE=deployment-settings.dev.json
