  "environment_write": false,
  "renderer_surfaces": [
    {
      "surface": "assigned_forms",
      "responsibility": "Show active published forms assigned to the signed-in Dataverse user/email."
    },
    {
      "surface": "submission_history",
      "responsibility": "Show the current user's own Draft, Submitted, and Locked submissions for a selected form."
    },
    {
      "surface": "form_runner_shell",
      "responsibility": "Load ordered Sections and Questions, manage progress, validation, save state, submit, and read-only locked state."
    },
    {
      "surface": "field_renderer",
      "responsibility": "Render MVP field types from Questions, Choices, and ValidationRules metadata."
    },
    {
      "surface": "attachment_capture",
      "responsibility": "Attach one photo/file to a Submission and Question through SubmissionFiles."
    }
  ],
  "dataverse_metadata_extensions": {
    "mp_GroupDefinition": [
      {
        "column": "RenderMode",
        "type": "Choice",
        "values": [
          "Page",
          "FieldList",
          "RepeatList",
          "ReviewOnly"
        ],
        "default": "Page",
        "purpose": "Controls whether the group renders as a page, a multi-field page, a repeat manager/list, or a review-only summary."
      },
      {
        "column": "NavigationMode",
        "type": "Choice",
        "values": [
          "Linear",
          "SectionJumpAllowed",
