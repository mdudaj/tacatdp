  "contract_name": "metadata-driven-form-renderer",
  "version": "0.2.0",
  "purpose": "Define the July 7 MVP renderer contract for one assigned published form rendered from Dataverse metadata, with drafts, submit, edit-until-locked, history, and one attachment field.",
