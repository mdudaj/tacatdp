  "supported_rule_expression_subset": [
    {
      "rule_type": "required",
      "supported_first_slice": true,
      "notes": "Required is enforced only when the group and field are visible/relevant."
    },
    {
      "rule_type": "relevance",
      "supported_first_slice": true,
      "operators": [
        "IsBlank",
        "Not",
        "=",
        "<>",
        ">",
        ">=",
        "<",
        "<=",
        "And",
        "Or",
        "selected"
      ],
      "notes": "First implementation should translate a reviewed subset of XLSForm relevance expressions to Power Fx."
    },
    {
      "rule_type": "constraint",
      "supported_first_slice": true,
      "operators": [
        "=",
        "<>",
        ">",
        ">=",
        "<",
        "<=",
        "regex",
        "string-length"
      ],
      "notes": "Use explicit visible errors; do not silently accept invalid values."
    },
    {
      "rule_type": "choice_filter",
      "supported_first_slice": true,
      "notes": "Must be delegation-safe for Dataverse. Village filters use mp_VillageReference RegionCode, DistrictCode, and WardCode indexes."
    },
    {
      "rule_type": "calculation",
      "supported_first_slice": "limited",
      "notes": "Support simple arithmetic and selected-count summaries first; defer complex XPath/repeat calculations."
    }
